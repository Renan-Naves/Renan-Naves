# Credenciais do Google Ads MCP (oficial) — COPIE para `google-ads.yaml` (gitignorado)
# e preencha. São as MESMAS credenciais dos env vars GOOGLE_ADS_* do Cloudflare.
# developer_token / client_secret / refresh_token são SEGREDOS — nunca commitar.
# Ver docs/google-ads-mcp.md.

developer_token: "__REPLACE_ME__"                 # 22 chars; conta real exige Basic Access
client_id: "__REPLACE_ME__.apps.googleusercontent.com"
client_secret: "__REPLACE_ME__"
refresh_token: "__REPLACE_ME__"                   # escopo https://www.googleapis.com/auth/adwords
login_customer_id: "3378698997"                   # MCC One Tree Eitch (337-869-8997), só dígitos — CONFIRMAR

use_proto_plus: true
